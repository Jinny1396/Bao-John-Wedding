{
  "entities": {
    "rsvp": {
      "title": "RSVP",
      "description": "Information collected from wedding RSVP submissions",
      "type": "object",
      "properties": {
        "guestName": {
          "type": "string",
          "description": "Full name of the guest"
        },
        "attendingStatus": {
          "type": "string",
          "enum": ["yes", "no"],
          "description": "Attendance status choice"
        },
        "dietaryRestrictions": {
          "type": "string",
          "description": "Any dietary restrictions or preferences"
        },
        "coupleNote": {
          "type": "string",
          "description": "A personal message or note for the couple"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Server-side creation timestamp"
        }
      },
      "required": ["guestName", "attendingStatus", "dietaryRestrictions", "coupleNote", "createdAt"]
    }
  },
  "firestore": {
    "rsvps/{rsvpId}": {
      "schema": "rsvp",
      "description": "Collection of RSVP submissions"
    }
  }
}
