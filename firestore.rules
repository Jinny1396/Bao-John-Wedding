rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Rule block for rsvps collection – dynamic document ID validation during create
    match /rsvps/{rsvpId} {
      // PUBLIC ACCESS POLICY: Allows ANY unauthenticated public user to WRITE (create) documents
      // so wedding guests can submit their RSVPs.
      // But strictly blocks them from READING, updating, or deleting existing documents
      // to ensure absolute guest list privacy.
      allow create: if isValidId(rsvpId) && isValidRSVP(incoming());
      
      // ADMIN ACCESS POLICY: Allows only the authenticated admin to READ the guest list.
      allow read: if request.auth != null 
        && request.auth.token.email == "jminxiii@gmail.com" 
        && request.auth.token.email_verified == true;
        
      allow update, delete: if false;
    }

    // Validation helper matching the schema defined in firebase-blueprint.json
    function isValidRSVP(data) {
      return data.keys().hasAll(['guestName', 'attendingStatus', 'dietaryRestrictions', 'coupleNote', 'createdAt'])
        && data.keys().size() == 5
        && data.guestName is string
        && data.guestName.size() > 0
        && data.guestName.size() <= 256
        && data.attendingStatus is string
        && (data.attendingStatus == 'yes' || data.attendingStatus == 'no')
        && data.dietaryRestrictions is string
        && data.dietaryRestrictions.size() <= 1000
        && data.coupleNote is string
        && data.coupleNote.size() <= 2000
        && data.createdAt == request.time;
    }
  }
}
